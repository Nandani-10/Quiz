// ══════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════
function goTo(screenId) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const map = {
    'landing': 'screen-landing',
    'join': 'screen-join',
    'participant': 'screen-participant',
    'host-setup': 'screen-host-setup',
    'host': 'screen-host',
    'leaderboard': 'screen-leaderboard'
  };
  const el = document.getElementById(map[screenId] || screenId);
  if (el) el.classList.add('active');
}

// ══════════════════════════════════════
// BROADCAST (using localStorage for cross-tab)
// ══════════════════════════════════════
function broadcastState(data) {
  localStorage.setItem(STATE_KEY, JSON.stringify({ ...data, ts: Date.now() }));
}

function readState() {
  try { return JSON.parse(localStorage.getItem(STATE_KEY) || 'null'); } catch { return null; }
}

function saveAnswers(answers) {
  localStorage.setItem(ANSWERS_KEY, JSON.stringify(answers));
}

function readAnswers() {
  try { return JSON.parse(localStorage.getItem(ANSWERS_KEY) || '[]'); } catch { return []; }
}

function saveParticipants(p) {
  localStorage.setItem(PARTICIPANTS_KEY, JSON.stringify(p));
}

function readParticipants() {
  try { return JSON.parse(localStorage.getItem(PARTICIPANTS_KEY) || '[]'); } catch { return []; }
}

// ══════════════════════════════════════
// PARTICIPANT JOIN
// ══════════════════════════════════════
function joinQuiz() {
  const name = document.getElementById('participant-name').value.trim();
  if (!name) { showToast('Please enter your name'); return; }
  myName = name;
  myRole = 'participant';
  myScore = 0;
  myCorrect = 0;

  // Register participant
  const participants = readParticipants();
  if (!participants.find(p => p.name === name)) {
    participants.push({ name, score: 0, correct: 0, joinedAt: Date.now() });
    saveParticipants(participants);
  }

  document.getElementById('join-form-section').style.display = 'none';
  document.getElementById('join-waiting-section').style.display = 'block';
  document.getElementById('joined-name-display').textContent = `Joined as: ${name}`;

  // Poll for state changes
  startParticipantPolling();
}

function startParticipantPolling() {
  let lastTs = 0;
  pollInterval = setInterval(() => {
    const state = readState();
    if (!state || state.ts === lastTs) return;
    lastTs = state.ts;
    handleStateChange(state);
  }, 500);
}

function handleStateChange(state) {
  if (state.type === 'question') {
    answerSubmitted = false;
    answerTime = null;
    questionStartTime = state.startTime;
    goTo('participant');
    showParticipantQuestion(state);
  } else if (state.type === 'reveal') {
    if (!answerSubmitted) {
      showParticipantResult(false, null, state.correctIndex, state.question);
    } else {
      // Already shown result inline
    }
  } else if (state.type === 'leaderboard') {
    goTo('leaderboard');
    renderLeaderboard(state.scores);
    launchConfetti();
  } else if (state.type === 'waiting') {
    if (myRole === 'participant') {
      goTo('join');
      document.getElementById('join-form-section').style.display = 'none';
      document.getElementById('join-waiting-section').style.display = 'block';
    }
  }
}

// ══════════════════════════════════════
// PARTICIPANT QUESTION UI
// ══════════════════════════════════════
function showParticipantQuestion(state) {
  document.getElementById('participant-idle').style.display = 'none';
  document.getElementById('participant-result-view').style.display = 'none';
  const qv = document.getElementById('participant-question-view');
  qv.style.display = 'block';

  const q = state.question;
  currentQIndex = state.qIndex;
  timePerQ = state.timePerQ;
  timeLeft = state.timePerQ;
  currentQuestions = state.questions || [];

  document.getElementById('p-q-number').textContent = `QUESTION ${state.qIndex + 1} OF ${state.total}`;
  document.getElementById('p-question-text').textContent = q.question;

  const grid = document.getElementById('p-options-grid');
  grid.innerHTML = '';
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-letter">${'ABCD'[i]}</span>${opt}`;
    btn.onclick = () => submitAnswer(i, btn);
    grid.appendChild(btn);
  });

  startParticipantTimer(state.timePerQ, state.startTime);
}

function startParticipantTimer(duration, startTime) {
  if (questionTimerInterval) clearInterval(questionTimerInterval);
  const elapsed = (Date.now() - startTime) / 1000;
  timeLeft = Math.max(0, duration - elapsed);

  const fill = document.getElementById('p-timer-fill');
  function tick() {
    const pct = (timeLeft / duration) * 100;
    fill.style.width = pct + '%';
    fill.className = 'timer-fill' + (timeLeft < 10 ? ' danger' : timeLeft < duration * 0.4 ? ' warning' : '');
    timeLeft -= 0.1;
    if (timeLeft <= 0) {
      clearInterval(questionTimerInterval);
      if (!answerSubmitted) {
        // Time's up — show no answer
        disableAllOptions();
        showParticipantResult(false, null, null, null);
      }
    }
  }
  tick();
  questionTimerInterval = setInterval(tick, 100);
}

function disableAllOptions() {
  document.querySelectorAll('.option-btn').forEach(b => b.disabled = true);
}

function submitAnswer(index, btn) {
  if (answerSubmitted) return;
  answerSubmitted = true;
  answerTime = Date.now();
  disableAllOptions();
  btn.classList.add('selected');

  const state = readState();
  if (!state) return;
  const correct = index === state.question.correct;

  // Calculate points (faster = more points, max 1000)
  let pts = 0;
  if (correct) {
    const elapsed = (answerTime - state.startTime) / 1000;
    const frac = Math.max(0, 1 - elapsed / state.timePerQ);
    pts = Math.round(500 + frac * 500);
    myScore += pts;
    myCorrect += 1;
  }

  // Record answer
  const answers = readAnswers();
  answers.push({ name: myName, qIndex: state.qIndex, chosen: index, correct, pts, time: answerTime - state.startTime });
  saveAnswers(answers);

  // Update score in participants
  const participants = readParticipants();
  const me = participants.find(p => p.name === myName);
  if (me) { me.score = myScore; me.correct = myCorrect; }
  saveParticipants(participants);

  // Update badge
  document.getElementById('p-score-badge').textContent = `Score: ${myScore}`;

  showParticipantResult(correct, pts, state.question.correct, state.question);
}

function showParticipantResult(correct, pts, correctIndex, question) {
  document.getElementById('participant-question-view').style.display = 'none';
  document.getElementById('participant-result-view').style.display = 'block';

  if (correct) {
    document.getElementById('result-icon').textContent = '✅';
    document.getElementById('result-msg').textContent = 'Correct! 🎉';
    document.getElementById('result-pts').textContent = `+${pts} pts`;
  } else if (pts === null && correctIndex === null) {
    document.getElementById('result-icon').textContent = '⏰';
    document.getElementById('result-msg').textContent = 'Time\'s up!';
    document.getElementById('result-pts').textContent = `+0 pts`;
  } else {
    document.getElementById('result-icon').textContent = '❌';
    document.getElementById('result-msg').textContent = `Wrong! Answer: ${question ? question.options[correctIndex] : ''}`;
    document.getElementById('result-pts').textContent = `+0 pts`;
  }
}

// ══════════════════════════════════════
// HOST: GENERATE QUESTIONS
// ══════════════════════════════════════
const PRESENTATION_CONTEXT = `Salesforce Prompt Builder presentation covering: Prompt Templates & Its Types. Key topics: 
- What is a Prompt, Prompt Template, and Prompt Builder
- 5 architecture layers: Prompt Layer, Merge Field Layer, Resource Layer, Template Layer, Execution/Delivery Layer
- 4 major template types: Sales Email (entry point: Email Composer, Draft with Einstein button), Field Generation (entry point: Einstein star button, requires Dynamic Forms/LAB), Record Summary (auto-displays in Highlights Panel, no user action), Flex (Apex/Flow/API, up to 5 custom inputs, most versatile)
- Merge fields: Input fields, Related object fields (syntax: {!$Input:Object.Field}), Related Lists ({!$RelatedList:Object.Field}), max 50 total, max 5 Flow, 5 Apex, 5 Related List, 5 Flex inputs
- Grounding: connecting prompts to CRM data for specific accurate responses
- LLM parameters: Temperature (0-2, low=deterministic, high=creative), Max Tokens, Frequency Penalty (penalises frequent tokens), Presence Penalty (penalises any appearance), Top-P, Stop Sequences
- Versioning: Draft → Preview → Activate → Monitor → Revise; activating makes version immutable; max 50 versions
- Batch processing: Flow (no-code, template-triggered) and Apex (custom); max 1000 AiJobRunItems standard, 10000 native batch; max 5 AiJobRun objects per 24hrs
- Hard limits: 128,000 char template size, 50 versions, 50 merge fields total, 15MB file size
- Einstein Trust Layer: masks PII before LLM, zero-retention policy for all external models`;

async function generateQuestions() {
  const n = parseInt(document.getElementById('num-questions').value);
  const diff = document.getElementById('difficulty').value;
  timePerQ = parseInt(document.getElementById('time-per-q').value);

  document.getElementById('gen-overlay').style.display = 'flex';
  document.getElementById('gen-msg').textContent = 'Generating quiz questions with AI...';

  try {
    const prompt = `You are a quiz creator. Based on this Salesforce Prompt Builder presentation content, generate exactly ${n} multiple-choice quiz questions at ${diff} difficulty.

Content: ${PRESENTATION_CONTEXT}

Return ONLY valid JSON array, no markdown, no backticks, no explanation:
[
  {
    "question": "Question text here?",
    "options": ["Option A", "Option B", "Option C", "Option D"],
    "correct": 0,
    "explanation": "Brief explanation why this is correct"
  }
]

Rules:
- "correct" is the 0-based index of the correct option
- All 4 options must be plausible
- Questions must be factual and based only on the content provided
- ${diff === 'hard' ? 'Include tricky questions about specific numbers, limits, and syntax' : diff === 'easy' ? 'Focus on core concepts and definitions' : 'Mix conceptual and specific questions'}
- Return exactly ${n} questions`;

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await response.json();
    const text = data.content.map(c => c.text || '').join('');
    const clean = text.replace(/```json|```/g, '').trim();
    currentQuestions = JSON.parse(clean);

    if (!Array.isArray(currentQuestions) || currentQuestions.length === 0) throw new Error('Empty');
  } catch (e) {
    console.warn('AI generation failed, using fallback:', e);
    const n2 = parseInt(document.getElementById('num-questions').value);
    currentQuestions = FALLBACK_QUESTIONS.slice(0, Math.min(n2, FALLBACK_QUESTIONS.length));
    showToast('Using pre-built questions (AI unavailable)');
  }

  document.getElementById('gen-overlay').style.display = 'none';
  launchHostDashboard();
}

// ══════════════════════════════════════
// HOST DASHBOARD
// ══════════════════════════════════════
function launchHostDashboard() {
  myRole = 'host';
  currentQIndex = -1;

  // Clear previous session data
  saveAnswers([]);
  const sessionCode = Math.random().toString(36).slice(2,6).toUpperCase();
  document.getElementById('session-code-display').textContent = sessionCode;

  goTo('host');
  renderQList();
  broadcastState({ type: 'waiting' });

  // Poll participants
  startHostPolling();
}

function renderQList() {
  const list = document.getElementById('host-q-list');
  list.innerHTML = '';
  currentQuestions.forEach((q, i) => {
    const item = document.createElement('div');
    item.className = 'q-item' + (i < currentQIndex ? ' done' : '') + (i === currentQIndex ? ' active' : '');
    item.id = `q-item-${i}`;
    item.innerHTML = `<span class="q-num">${i+1}</span><span class="q-preview">${q.question.slice(0,60)}${q.question.length>60?'…':''}</span>`;
    item.onclick = () => launchQuestion(i);
    list.appendChild(item);
  });
}

function startHostPolling() {
  setInterval(() => {
    const participants = readParticipants();
    document.getElementById('p-count').textContent = participants.length;
    document.getElementById('stat-participants').textContent = participants.length;

    const pList = document.getElementById('participants-list');
    pList.innerHTML = '';
    participants.forEach(p => {
      const chip = document.createElement('div');
      chip.className = 'participant-chip';
      const answers = readAnswers();
      const answered = currentQIndex >= 0 && answers.some(a => a.name === p.name && a.qIndex === currentQIndex);
      chip.innerHTML = `<div class="participant-dot ${answered ? 'answered' : ''}"></div><span>${p.name}</span><span style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent)">${p.score || 0}</span>`;
      pList.appendChild(chip);
    });

    // Update live answer counts
    if (currentQIndex >= 0) {
      const answers = readAnswers().filter(a => a.qIndex === currentQIndex);
      document.getElementById('stat-answered').textContent = answers.length;
      updateLiveAnswerBars(answers);
    }
  }, 800);
}

function launchNextQuestion() {
  launchQuestion(0);
}

function launchQuestion(index) {
  if (index >= currentQuestions.length) {
    showLeaderboard();
    return;
  }
  currentQIndex = index;
  const q = currentQuestions[index];
  const startTime = Date.now();

  // Broadcast to participants
  broadcastState({
    type: 'question',
    qIndex: index,
    total: currentQuestions.length,
    question: q,
    questions: currentQuestions,
    timePerQ,
    startTime
  });

  // Update host UI
  document.getElementById('host-idle').style.display = 'none';
  document.getElementById('host-reveal').style.display = 'none';
  document.getElementById('host-active-q').style.display = 'flex';
  document.getElementById('stat-q-num').textContent = `${index+1}/${currentQuestions.length}`;
  document.getElementById('hq-label').textContent = `QUESTION ${index+1} OF ${currentQuestions.length}`;
  document.getElementById('hq-text').textContent = q.question;

  const opts = document.getElementById('hq-options');
  opts.innerHTML = '';
  q.options.forEach((opt, i) => {
    const d = document.createElement('div');
    d.className = 'hq-opt' + (i === q.correct ? ' correct-ans' : '');
    d.innerHTML = `<span class="hq-opt-letter">${'ABCD'[i]}</span>${opt}`;
    opts.appendChild(d);
  });

  // Live answer bars init
  const grid = document.getElementById('live-answers-grid');
  grid.innerHTML = '';
  q.options.forEach((opt, i) => {
    const bar = document.createElement('div');
    bar.className = 'ans-bar' + (i === q.correct ? ' winner' : '');
    bar.id = `ans-bar-${i}`;
    bar.innerHTML = `<div class="ans-count" id="ans-count-${i}">0</div><div class="ans-label">${'ABCD'[i]}: ${opt.slice(0,20)}${opt.length>20?'…':''}</div>`;
    grid.appendChild(bar);
  });

  renderQList();
  startHostTimer(startTime);
}

function updateLiveAnswerBars(answers) {
  const counts = [0, 0, 0, 0];
  answers.forEach(a => { if (a.chosen >= 0 && a.chosen < 4) counts[a.chosen]++; });
  counts.forEach((c, i) => {
    const el = document.getElementById(`ans-count-${i}`);
    if (el) el.textContent = c;
  });
}

function startHostTimer(startTime) {
  if (questionTimerInterval) clearInterval(questionTimerInterval);
  function tick() {
    const elapsed = (Date.now() - startTime) / 1000;
    const remaining = Math.max(0, timePerQ - elapsed);
    document.getElementById('host-timer-display').textContent = Math.ceil(remaining) + 's';
    const pct = (remaining / timePerQ) * 100;
    const fill = document.getElementById('h-timer-fill');
    fill.style.width = pct + '%';
    fill.className = 'timer-fill' + (remaining < 10 ? ' danger' : remaining < timePerQ * 0.4 ? ' warning' : '');
    if (remaining <= 0) { clearInterval(questionTimerInterval); endQuestion(); }
  }
  tick();
  questionTimerInterval = setInterval(tick, 200);
}

function endQuestion() {
  clearInterval(questionTimerInterval);
  const q = currentQuestions[currentQIndex];
  broadcastState({ type: 'reveal', correctIndex: q.correct, question: q, qIndex: currentQIndex, total: currentQuestions.length });

  document.getElementById('host-active-q').style.display = 'none';
  document.getElementById('host-reveal').style.display = 'flex';

  // Reveal card
  const card = document.getElementById('host-reveal-card');
  card.innerHTML = `
    <div class="hq-label">ANSWER REVEALED — Q${currentQIndex+1}</div>
    <div class="hq-text">${q.question}</div>
    <div class="hq-options">${q.options.map((o,i)=>`<div class="hq-opt${i===q.correct?' correct-ans':''}"><span class="hq-opt-letter">${'ABCD'[i]}</span>${o}</div>`).join('')}</div>
    ${q.explanation ? `<div style="margin-top:16px;padding:12px 16px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:10px;font-size:14px;color:var(--correct)">💡 ${q.explanation}</div>` : ''}
  `;

  // Top 10
  const answers = readAnswers().filter(a => a.qIndex === currentQIndex && a.correct);
  answers.sort((a,b) => a.time - b.time);
  const top10 = answers.slice(0, 10);
  const top10El = document.getElementById('host-top10');
  top10El.innerHTML = '';
  if (top10.length === 0) {
    top10El.innerHTML = '<div style="color:var(--muted);font-size:14px">No correct answers yet</div>';
  } else {
    top10.forEach((a, i) => {
      const d = document.createElement('div');
      d.style.cssText = 'display:flex;align-items:center;gap:12px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 16px';
      d.innerHTML = `<span style="font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:700;color:var(--muted);width:24px">#${i+1}</span><span style="flex:1;font-size:14px">${a.name}</span><span style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--correct)">+${a.pts} pts · ${(a.time/1000).toFixed(1)}s</span>`;
      top10El.appendChild(d);
    });
  }
}

function nextQuestion() {
  launchQuestion(currentQIndex + 1);
}

function showLeaderboard() {
  clearInterval(questionTimerInterval);
  const participants = readParticipants();
  const answers = readAnswers();

  // Compute final scores
  const scoreMap = {};
  answers.forEach(a => {
    if (!scoreMap[a.name]) scoreMap[a.name] = { score: 0, correct: 0 };
    scoreMap[a.name].score += a.pts || 0;
    if (a.correct) scoreMap[a.name].correct++;
  });

  // Merge with registered participants
  participants.forEach(p => {
    if (!scoreMap[p.name]) scoreMap[p.name] = { score: 0, correct: 0 };
  });

  const scores = Object.entries(scoreMap)
    .map(([name, d]) => ({ name, ...d }))
    .sort((a, b) => b.score - a.score);

  broadcastState({ type: 'leaderboard', scores });
  goTo('leaderboard');
  renderLeaderboard(scores);
  launchConfetti();
}

function renderLeaderboard(scores) {
  const list = document.getElementById('leaderboard-list');
  list.innerHTML = '';
  const medals = ['🥇', '🥈', '🥉'];
  scores.slice(0, 15).forEach((s, i) => {
    const row = document.createElement('div');
    row.className = 'lb-row';
    row.style.animationDelay = (i * 0.07) + 's';
    const rankClass = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '';
    row.innerHTML = `
      <div class="lb-rank ${rankClass}">${medals[i] || (i+1)}</div>
      <div class="lb-name">${s.name}</div>
      <div class="lb-correct">${s.correct || 0} correct</div>
      <div class="lb-score">${s.score || 0} pts</div>
    `;
    list.appendChild(row);
  });
  if (scores.length === 0) {
    list.innerHTML = '<div style="text-align:center;color:var(--muted);padding:40px">No participants yet</div>';
  }
}

function returnToHost() {
  goTo('host');
}

function restartQuiz() {
  saveAnswers([]);
  saveParticipants([]);
  currentQIndex = -1;
  broadcastState({ type: 'waiting' });
  goTo('landing');
}

// ══════════════════════════════════════
// CONFETTI
// ══════════════════════════════════════
function launchConfetti() {
  const container = document.getElementById('confetti-container');
  container.innerHTML = '';
  const colors = ['#00d4ff', '#7c3aed', '#10b981', '#f59e0b', '#ef4444', '#ffffff'];
  for (let i = 0; i < 120; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.cssText = `
      left: ${Math.random()*100}%;
      top: -20px;
      background: ${colors[Math.floor(Math.random()*colors.length)]};
      animation-duration: ${1.5 + Math.random()*2}s;
      animation-delay: ${Math.random()*1.5}s;
      transform: rotate(${Math.random()*360}deg);
      width: ${4 + Math.random()*8}px;
      height: ${4 + Math.random()*8}px;
    `;
    container.appendChild(piece);
  }
  setTimeout(() => { container.innerHTML = ''; }, 4000);
}

// ══════════════════════════════════════
// TOAST
// ══════════════════════════════════════
function showToast(msg) {
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
// Clear old state on fresh load
if (!localStorage.getItem('qlive_init')) {
  localStorage.removeItem(STATE_KEY);
  localStorage.removeItem(ANSWERS_KEY);
  localStorage.removeItem(PARTICIPANTS_KEY);
}

// Listen for storage events (cross-tab)
window.addEventListener('storage', (e) => {
  if (e.key === STATE_KEY && myRole === 'participant') {
    const state = readState();
    if (state) handleStateChange(state);
  }
});
</script>
