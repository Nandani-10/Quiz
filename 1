const STATE_KEY = 'qlive_state';
const ANSWERS_KEY = 'qlive_answers';
const PARTICIPANTS_KEY = 'qlive_participants';

let myRole = null; // 'host' | 'participant'
let myName = '';
let myScore = 0;
let myCorrect = 0;
let questionTimerInterval = null;
let timeLeft = 30;
let timePerQ = 30;
let answerSubmitted = false;
let answerTime = null;
let questionStartTime = null;
let currentQuestions = [];
let currentQIndex = -1;
let pollInterval = null;

// Pre-baked fallback questions (from presentation content)
const FALLBACK_QUESTIONS = [
